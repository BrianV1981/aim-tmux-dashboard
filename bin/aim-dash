#!/bin/bash
# A simple TUI dashboard to manage running tmux sessions

GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

while true; do
    clear
    echo -e "${CYAN}================================================${NC}"
    echo -e "${GREEN} 🚀 A.I.M. Tmux Dashboard (Backend Admin Panel) ${NC}"
    echo -e "${CYAN}================================================${NC}"
    
    # Grab all active tmux sessions
    mapfile -t SESSIONS < <(tmux ls 2>/dev/null | awk -F: '{print $1}')
    
    if [ ${#SESSIONS[@]} -eq 0 ]; then
        echo -e " ${YELLOW}No active background uploads or tasks.${NC}"
        echo ""
    else
        echo -e " Active Sessions:"
        for i in "${!SESSIONS[@]}"; do
            echo -e "  [${GREEN}$i${NC}] ${SESSIONS[$i]}"
        done
        echo ""
    fi
    
    echo -e "${CYAN}--- Controls ---${NC}"
    if [ ${#SESSIONS[@]} -gt 0 ]; then
        MAX_INDEX=$((${#SESSIONS[@]}-1))
        echo -e " [${GREEN}0-${MAX_INDEX}${NC}] Attach to session (Ctrl+B then D to return)"
        echo -e " [${RED}k${NC}] Kill / Delete a session"
    fi
    echo -e " [${GREEN}n${NC}] Create New Tmux Workspace"
    echo -e " [${YELLOW}q${NC}] Quit Dashboard"
    echo -e "${CYAN}================================================${NC}"
    
    read -p " Select option: " choice
    
    if [[ "$choice" == "q" || "$choice" == "Q" ]]; then
        clear
        exit 0
    elif [[ "$choice" == "n" || "$choice" == "N" ]]; then
        echo ""
        read -p " Enter a name for the new session: " session_name
        read -p " Enter command to run (leave blank for standard shell): " session_cmd
        if [ -n "$session_name" ]; then
            # Generate a safe, unique tmux session name
            safe_name=$(echo "$session_name" | sed 's/[^a-zA-Z0-9-]/_/g' | cut -c 1-20)
            echo -e "${GREEN}Spawning isolated workspace '$safe_name'...${NC}"
            if [ -n "$session_cmd" ]; then
                tmux new-session -d -s "$safe_name" "$session_cmd"
            else
                tmux new-session -d -s "$safe_name"
            fi
            sleep 1
        fi
    elif [[ "$choice" == "k" || "$choice" == "K" ]] && [ ${#SESSIONS[@]} -gt 0 ]; then
        echo ""
        read -p " Enter the number of the session to terminate: " kill_num
        if [[ "$kill_num" =~ ^[0-9]+$ ]] && [ "$kill_num" -lt "${#SESSIONS[@]}" ]; then
            tmux kill-session -t "${SESSIONS[$kill_num]}"
            echo -e "${RED}Session '${SESSIONS[$kill_num]}' destroyed.${NC}"
            sleep 1
        else
            echo -e "${RED}Invalid selection.${NC}"
            sleep 1
        fi
    elif [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -lt "${#SESSIONS[@]}" ]; then
        tmux attach -t "${SESSIONS[$choice]}"
    fi
done
