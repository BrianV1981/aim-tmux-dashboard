#!/bin/bash
# A.I.M. Tmux Dashboard Entrypoint

# Get the directory of this script
DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"
PROJECT_ROOT="$(dirname "$DIR")"

PY="$PROJECT_ROOT/venv/bin/python"
if [[ ! -x "$PY" ]]; then
    echo "Error: Python virtual environment not found or not executable." >&2
    echo "Please run: ./scripts/setup.sh" >&2
    exit 1
fi

# Execute the Textual dashboard using the virtual environment, passing all arguments
exec "$PY" "$DIR/dashboard.py" "$@"
